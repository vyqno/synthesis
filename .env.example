# =============================================================================
# Nexus Protocol — Environment Variables
# Copy to .env and fill in real values before running.
# NEVER commit .env to git.
# =============================================================================

# -----------------------------------------------------------------------------
# Required for deployment
# -----------------------------------------------------------------------------
PRIVATE_KEY=0x...                     # Deployer/agent wallet private key (hex)
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
ETH_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY   # Mainnet (for staking data)
ETHERSCAN_API_KEY=                    # Etherscan API key for contract verification

# Arbitrum / Base / Celo (optional — only needed if deploying to those chains)
ARBITRUM_RPC_URL=https://arb-mainnet.g.alchemy.com/v2/YOUR_KEY
BASE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY
ARBISCAN_API_KEY=
BASESCAN_API_KEY=
CELO_RPC_URL=
STATUS_NETWORK_RPC_URL=https://public.sepolia.rpc.status.network

# Mainnet RPC (only needed for mainnet deploy — handle with extreme care)
MAINNET_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY

# -----------------------------------------------------------------------------
# Required for agent runtime
# -----------------------------------------------------------------------------
VENICE_API_KEY=                       # Venice.ai private LLM (primary)
GROQ_API_KEY=                         # Groq fast LLM (fallback)
BANKR_API_KEY=                        # Bankr payment gateway
BANKR_WALLET_ADDRESS=                 # Bankr wallet address

# -----------------------------------------------------------------------------
# Required for hackathon submission
# -----------------------------------------------------------------------------
SYNTHESIS_API_KEY=                    # Synthesis hackathon submission API
SYNTHESIS_TEAM_ID=                    # Synthesis team ID

# -----------------------------------------------------------------------------
# Protocol integrations (optional — enable extra features)
# -----------------------------------------------------------------------------
UNISWAP_API_KEY=                      # Uniswap v4 hooks
LOCUS_API_KEY=                        # Locus protocol
ZYFAI_API_KEY=                        # ZyfAI
LIT_API_KEY=                          # Lit Protocol (access control)
SELF_API_KEY=                         # Self.id (identity)
FILECOIN_TOKEN=                       # Filecoin/IPFS storage

# -----------------------------------------------------------------------------
# Optional — monitoring / alerts
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=                   # Telegram bot for monitor alerts
TELEGRAM_CHAT_ID=                     # Telegram chat ID for alerts
